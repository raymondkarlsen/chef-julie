---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import MetaIcon from '../../components/MetaIcon.astro';
import { url } from '../../lib/url';
import { getRecipes, urlForImage, type Recipe } from '../../lib/sanity';

export async function getStaticPaths() {
  const recipes = await getRecipes();
  return recipes.map((recipe) => ({
    params: { slug: recipe.slug },
    props: { recipe },
  }));
}

const { recipe: data } = Astro.props as { recipe: Recipe };

const heroUrl = data.heroImage?.asset
  ? urlForImage(data.heroImage).width(1200).height(720).fit('crop').auto('format').url()
  : null;

const metaItems = [
  data.servings
    ? { icon: 'servings' as const, label: 'Porsjoner', value: `${data.servings}` }
    : null,
  data.prepTime
    ? { icon: 'prep' as const, label: 'Forberedelse', value: data.prepTime }
    : null,
  data.totalTime
    ? { icon: 'total' as const, label: 'Totalt', value: data.totalTime }
    : null,
  data.difficulty
    ? { icon: 'difficulty' as const, label: 'Vanskelighet', value: data.difficulty }
    : null,
].filter((item) => item !== null);
---

<BaseLayout title={`${data.title} – Chef Julie`} description={data.ingress}>
  <SiteHeader slot="header" />
  <article class="recipe">
    <nav class="breadcrumb container" aria-label="Brødsmulesti">
      <a href={url()}>Oppskrifter</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{data.title}</span>
    </nav>

    <header class="recipe__header container">
      {data.category && <span class="tag">{data.category}</span>}
      <h1 class="recipe__title">{data.title}</h1>
      <p class="recipe__ingress">{data.ingress}</p>
      {
        data.tags.length > 0 && (
          <ul class="recipe__tags">
            {data.tags.map((tag) => (
              <li>#{tag}</li>
            ))}
          </ul>
        )
      }
    </header>

    {
      heroUrl && (
        <div class="recipe__hero container">
          <img
            src={heroUrl}
            alt={data.heroImage?.alt ?? data.title}
            width={1200}
            height={720}
          />
        </div>
      )
    }

    {
      metaItems.length > 0 && (
        <dl class="recipe__meta container">
          {metaItems.map((item) => (
            <div class="recipe__meta-item">
              <span class="recipe__meta-icon" aria-hidden="true">
                <MetaIcon name={item.icon} />
              </span>
              <dd>{item.value}</dd>
              <dt>{item.label}</dt>
            </div>
          ))}
        </dl>
      )
    }

    <div class="recipe__body container">
      {
        data.ingredientGroups.length > 0 && (
          <section class="recipe__ingredients" aria-labelledby="ingredienser">
            <h2 id="ingredienser">Ingredienser</h2>
            {data.ingredientGroups.map((group) => (
              <div class="recipe__ingredient-group">
                {group.heading && <h3>{group.heading}</h3>}
                <ul>
                  {group.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            ))}
          </section>
        )
      }

      <section class="recipe__steps" aria-labelledby="fremgangsmate">
        <h2 id="fremgangsmate">Slik gjør du</h2>
        {
          data.instructions.length > 0 && (
            <ol>
              {data.instructions.map((step) => (
                <li>{step}</li>
              ))}
            </ol>
          )
        }

        {
          data.tips.length > 0 && (
            <div class="recipe__tips">
              <h3>Tips</h3>
              <ul>
                {data.tips.map((tip) => (
                  <li>{tip}</li>
                ))}
              </ul>
            </div>
          )
        }
      </section>
    </div>

    <p class="recipe__back container">
      <a href={url()}>← Tilbake til alle oppskrifter</a>
    </p>
  </article>
</BaseLayout>

<style>
  .recipe__header {
    padding-block: var(--space-lg) var(--space-md);
    max-width: 46rem;
    text-align: center;
    margin-inline: auto;
  }

  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    padding-block: var(--space-md) 0;
  }

  .breadcrumb a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .breadcrumb [aria-current='page'] {
    color: var(--color-text);
    font-weight: 600;
  }

  .recipe__title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: var(--space-sm) 0;
  }

  .recipe__ingress {
    font-size: 1.2rem;
    color: var(--color-muted);
    margin: 0;
  }

  .recipe__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    justify-content: center;
    padding: 0;
    margin: var(--space-md) 0 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .recipe__hero :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    object-fit: cover;
  }

  .recipe__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
    justify-content: center;
    margin-block: var(--space-lg);
    padding: var(--space-md);
    border-block: 1px solid var(--color-border);
  }

  .recipe__meta-item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .recipe__meta-icon {
    font-size: 1.6rem;
    line-height: 1;
    margin-bottom: 0.2rem;
  }

  .recipe__meta-item dt {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    order: 3;
  }

  .recipe__meta-item dd {
    margin: 0;
    font-weight: 700;
    font-size: 1.1rem;
  }

  .recipe__body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  /* Seksjonsoverskrifter med aksent-strek – tydelig skille også på mobil */
  .recipe__ingredients h2,
  .recipe__steps h2,
  .recipe__gallery h2 {
    display: inline-block;
    margin: 0 0 var(--space-md);
    padding-bottom: 0.3rem;
    border-bottom: 3px solid var(--color-accent);
  }

  /* Ingredienser som eget kort på alle skjermstørrelser */
  .recipe__ingredients {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-md) var(--space-lg);
    box-shadow: var(--shadow);
  }

  @media (min-width: 52rem) {
    .recipe__body {
      grid-template-columns: 20rem 1fr;
    }

    .recipe__ingredients {
      position: sticky;
      top: var(--space-md);
    }
  }

  .recipe__ingredient-group h3 {
    font-size: 1rem;
    margin: var(--space-md) 0 var(--space-xs);
  }

  .recipe__ingredients ul {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }

  .recipe__ingredients li {
    position: relative;
    padding-left: 1.4rem;
    margin-bottom: 0.45rem;
  }

  .recipe__ingredients li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-accent);
  }

  /* Fremgangsmåte med nummererte sirkler */
  .recipe__steps ol {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: step;
  }

  .recipe__steps ol li {
    counter-increment: step;
    position: relative;
    padding-left: 3.25rem;
    margin-bottom: var(--space-lg);
    min-height: 2.25rem;
  }

  .recipe__steps ol li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0;
    width: 2.25rem;
    height: 2.25rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .recipe__tips {
    margin-top: var(--space-lg);
    background: var(--color-accent-soft);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius);
    padding: var(--space-md) var(--space-lg);
  }

  .recipe__tips h3 {
    margin-top: 0;
  }

  .recipe__tips ul {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }

  .recipe__tips li {
    position: relative;
    padding-left: 1.6rem;
    margin-bottom: 0.45rem;
  }

  .recipe__tips li::before {
    content: '💡';
    position: absolute;
    left: 0;
    top: 0;
    font-size: 0.9rem;
  }

  .recipe__gallery {
    margin-top: var(--space-xl);
  }

  .recipe__gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: var(--space-md);
  }

  .recipe__gallery-grid :global(img) {
    border-radius: var(--radius);
    object-fit: cover;
    width: 100%;
    height: 100%;
  }

  .recipe__back {
    margin-block: var(--space-xl);
  }
</style>
