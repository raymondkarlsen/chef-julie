---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Enkle og gode oppskrifter fra Chef Julie.' } = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Chef Julie. Laget med kjærlighet og god mat.</p>
      </div>
    </footer>
  </body>
</html>
